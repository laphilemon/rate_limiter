  "version": "0.2.0",
  "configurations": [
    
    {
      "type": "node",
      "request": "launch",
      "name": "Run ts-node-dev",
      "runtimeExecutable": "ts-node-dev",
      "cwd": "${workspaceFolder}",
      "args": []
